<Project Sdk="Microsoft.NET.Sdk">


    <PropertyGroup>
        <!-- The unique ID for your package on NuGet.org -->
        <PackageId>Aero.EfCore</PackageId>

        <!-- Increment this version every time you push a new update -->
        <Version>0.0.5-alpha</Version>

        <!-- Your name or organization -->
        <Authors>Microbians</Authors>

        <!-- A brief description shown in the NuGet gallery -->
        <Description>Aero core library with useful utility tools for any project</Description>

        <!-- Optional: High-quality metadata for better discoverability -->
        <PackageTags>aero;utils;netcore</PackageTags>
        <PackageProjectUrl>https://github.com/microbian-systems/aero</PackageProjectUrl>
        <RepositoryUrl>https://github.com/microbian-systems/aero</RepositoryUrl>
        <RepositoryType>git</RepositoryType>

        <!-- Optional: Automatically creates a package on every build -->
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    </PropertyGroup>
    
    <ItemGroup>
      <ProjectReference Include="..\Aero.Marten\Aero.Marten.csproj" />
      <ProjectReference Include="..\Aero.Models\Aero.Models.csproj" />
      <ProjectReference Include="..\Aero.Core\Aero.Core.csproj" />
    </ItemGroup>

    <ItemGroup>
      <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Microsoft.EntityFrameworkCore" />
      <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    </ItemGroup>

</Project>
